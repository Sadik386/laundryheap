# Server environment variables - copy to .env and fill in values

PORT=5000
GOOGLE_CLIENT_ID=your_google_client_id
STORE_ID=your_store_id
STORE_PASSWORD=your_store_password
IS_LIVE=false # or true for production
BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
STRIPE_SECRET_KEY=your_stripe_secret_key
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
MONGODB_URI=your_mongodb_connection_string

# Base64-encoded Google service account JSON (recommended)
# Generate locally and DO NOT commit the real file:
#   cat serviceAccountKey.json | base64
# Then copy the output here or set it in your deployment/CI secrets.
SERVICE_ACCOUNT_BASE64=your_base64_service_account_json
